---
// Portfolio — grid editorial con el primer item destacado (2×2).
// Las imágenes apuntan a rendex.es como placeholder temporal.
// TODO: Descarga los WebP a src/assets/renders/ y actualiza los src.

const items = [
  {
    src: "https://rendex.es/assets/images/3d-casa-jens-1692x952.webp",
    alt: "Render exterior residencial — vivienda unifamiliar en Tenerife",
    tag: "Exterior residencial",
    hero: true, // span 2 cols × 2 filas
  },
  {
    src: "https://rendex.es/assets/images/spa-atardecer-989x1308.webp",
    alt: "Render exterior spa al atardecer",
    tag: "Comercial · Spa",
  },
  {
    src: "https://rendex.es/assets/images/interior-dia-989x1314.webp",
    alt: "Render interior de día — salón contemporáneo",
    tag: "Interior",
  },
  {
    src: "https://rendex.es/assets/images/correa-piscina-2-1649x928.webp",
    alt: "Render exterior piscina y jardín",
    tag: "Exterior · Piscina",
  },
  {
    src: "https://rendex.es/assets/images/cuarto-dia-989x1492.webp",
    alt: "Render interior habitación de día",
    tag: "Interior · Habitación",
  },
  {
    src: "https://rendex.es/assets/images/office-dia-2058x1158.webp",
    alt: "Render interior oficina de día",
    tag: "Comercial · Oficina",
  },
  {
    src: "https://rendex.es/assets/images/correa-patio-1649x928.webp",
    alt: "Render exterior patio privado",
    tag: "Exterior · Patio",
  },
  {
    src: "https://rendex.es/assets/images/swimspa-1495x841.webp",
    alt: "Render exterior swim spa",
    tag: "Exterior · Swim Spa",
  },
];
---

<section id="portfolio">
  <div class="container">
    <div class="section-header anim-fade" id="portfolioHeader">
      <span class="section-eyebrow">Portfolio</span>
      <h2 class="section-title">Nuestro <em>trabajo</em></h2>
    </div>
  </div>

  <div class="container">
    <div class="portfolio-grid" id="portfolioGrid">
      {
        items.map((item) => (
          <div class={`portfolio-item anim-fade${item.hero ? " portfolio-item--hero" : ""}`}>
            <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
            <div class="portfolio-overlay">
              <span class="portfolio-tag">{item.tag}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  #portfolio {
    padding: var(--section-py) 0;
    background: var(--gray-lt);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 295px;
    gap: 10px;
  }

  /* Primer item: 2 columnas × 2 filas — imagen hero editorial */
  .portfolio-item--hero {
    grid-column: span 2;
    grid-row: span 2;
  }

  .portfolio-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .portfolio-item img {
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .portfolio-item:hover img {
    transform: scale(1.06);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 21, 32, 0.65) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.4s;
    display: flex;
    align-items: flex-end;
    padding: 22px 26px;
  }

  .portfolio-item:hover .portfolio-overlay {
    opacity: 1;
  }

  .portfolio-tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
  }

  /* Animación escalonada para los items */
  .portfolio-item:nth-child(1) { transition-delay: 0s; }
  .portfolio-item:nth-child(2) { transition-delay: 0.09s; }
  .portfolio-item:nth-child(3) { transition-delay: 0.18s; }
  .portfolio-item:nth-child(4) { transition-delay: 0.27s; }
  .portfolio-item:nth-child(5) { transition-delay: 0.36s; }
  .portfolio-item:nth-child(6) { transition-delay: 0.45s; }
  .portfolio-item:nth-child(7) { transition-delay: 0.54s; }
  .portfolio-item:nth-child(8) { transition-delay: 0.63s; }

  @media (max-width: 900px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
    }
  }

  @media (max-width: 540px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 260px;
    }

    .portfolio-item--hero {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>
