---
// Hero — imagen aérea de fondo con parallax, H1 y CTA.
// TODO: Sustituye la URL de hero-bg por el asset local optimizado en WebP
//       cuando muevas las imágenes a src/assets/renders/
---

<section class="hero" id="inicio">
  <!-- Fondo con parallax (JS nativo, sin GSAP) -->
  <!-- TODO: reemplazar URL por imagen local WebP -->
  <div
    class="hero-bg"
    id="heroBg"
    style="background-image: url('https://rendex.es/assets/images/drone-niebla-2058x1158.webp')"
    role="img"
    aria-label="Imagen aérea de un render arquitectónico en Tenerife"
  ></div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <span class="hero-eyebrow">Estudio de Visualización 3D · La Orotava, Tenerife</span>

    <!-- H1 único de la página -->
    <h1 class="hero-title">Renders que <em>venden</em></h1>

    <p class="hero-sub">
      Visualización arquitectónica de precisión para arquitectos,
      interioristas y promotoras.
    </p>

    <a href="#portfolio" class="hero-cta">Ver portfolio →</a>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <div class="hero-scroll-line"></div>
    <span class="hero-scroll-text">Scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 720px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transform: scale(1.08);
    will-change: transform;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(10, 21, 32, 0.65) 0%,
      rgba(10, 21, 32, 0.38) 55%,
      rgba(10, 21, 32, 0.75) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 0 24px;
    max-width: 840px;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
    margin-bottom: 28px;
    /* Estado inicial para animación de entrada */
    opacity: 0;
    transform: translateY(18px);
    animation: heroFadeUp 0.9s 0.25s ease forwards;
  }

  /* H1 */
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(58px, 9.5vw, 108px);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.01em;
    margin-bottom: 32px;
    opacity: 0;
    transform: translateY(28px);
    animation: heroFadeUp 1.1s 0.55s ease forwards;
  }

  .hero-title em {
    font-style: italic;
  }

  /* Subtítulo */
  .hero-sub {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.78;
    color: rgba(255, 255, 255, 0.7);
    max-width: 460px;
    margin: 0 auto 52px;
    opacity: 0;
    transform: translateY(18px);
    animation: heroFadeUp 0.85s 0.9s ease forwards;
  }

  /* CTA */
  .hero-cta {
    display: inline-block;
    padding: 15px 42px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    transition:
      background 0.35s,
      border-color 0.35s;
    opacity: 0;
    transform: translateY(18px);
    animation: heroFadeUp 0.7s 1.2s ease forwards;
  }

  .hero-cta:hover {
    background: rgba(255, 255, 255, 0.11);
    border-color: rgba(255, 255, 255, 0.85);
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    bottom: 44px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    z-index: 2;
  }

  .hero-scroll-line {
    width: 1px;
    height: 52px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.5), transparent);
    animation: scrollAnim 2.2s ease-in-out infinite;
  }

  .hero-scroll-text {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.38);
  }

  /* Keyframes */
  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scrollAnim {
    0% {
      opacity: 0;
      transform: scaleY(0);
      transform-origin: top;
    }
    40% {
      opacity: 1;
      transform: scaleY(1);
      transform-origin: top;
    }
    80% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  @media (max-width: 640px) {
    .hero-scroll {
      display: none;
    }
  }
</style>

<script>
  // Parallax del fondo sin GSAP — rAF nativo
  const heroBg = document.getElementById("heroBg") as HTMLElement;

  function onScroll() {
    const scrollY = window.scrollY;
    const heroHeight = heroBg.parentElement?.clientHeight ?? window.innerHeight;
    if (scrollY <= heroHeight) {
      const yPercent = (scrollY / heroHeight) * 18;
      heroBg.style.transform = `scale(1.08) translateY(${yPercent}%)`;
    }
  }

  window.addEventListener("scroll", onScroll, { passive: true });
</script>
