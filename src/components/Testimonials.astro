---
// Testimonials — reseñas de clientes reales sobre fondo oscuro.
const reviews = [
  {
    text: "Los renders superaron todas nuestras expectativas. Conseguimos vender el 80% de las unidades antes de comenzar la obra. Una inversión que se amortizó desde el primer día.",
    name: "María García",
    role: "Arquitecta · García & Asociados",
  },
  {
    text: "Los clientes no podían creer que fueran renders y no fotos reales. La calidad del detalle y la luz es impresionante. Comunicación excelente en todo el proceso.",
    name: "Carlos Ruiz",
    role: "Promotor Inmobiliario · Grupo Atlántico",
  },
  {
    text: "Rapidez, calidad y atención al detalle. Ya van tres proyectos con Rendex y siempre entregan por encima de lo esperado. Son mi primera llamada para cualquier visualización.",
    name: "Laura Méndez",
    role: "Interiorista · Studio LM",
  },
];
---

<section id="resenas">
  <div class="container">
    <div class="section-header anim-fade" id="resenasHeader">
      <span class="section-eyebrow">Clientes</span>
      <h2 class="section-title">Lo que dicen de <em>nosotros</em></h2>
    </div>

    <div class="reviews-grid" id="reviewsGrid">
      {
        reviews.map((r, i) => (
          <article class="review-card anim-fade" data-delay={i * 120}>
            <div class="review-quote" aria-hidden="true">"</div>
            <p class="review-text">{r.text}</p>
            <footer class="review-author">
              <div class="review-name">{r.name}</div>
              <div class="review-role">{r.role}</div>
            </footer>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  #resenas {
    padding: var(--section-py) 0;
    background: var(--dark);
  }

  #resenas .section-eyebrow {
    color: #5b9bd5;
  }

  #resenas .section-title {
    color: var(--white);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .review-card {
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    transition: border-color 0.35s;
  }

  .review-card:hover {
    border-color: rgba(255, 255, 255, 0.25);
  }

  /* Comilla decorativa grande en Cormorant */
  .review-quote {
    font-family: var(--font-display);
    font-size: 64px;
    line-height: 0.7;
    color: var(--blue-mid);
    user-select: none;
  }

  .review-text {
    font-size: 15px;
    line-height: 1.78;
    color: rgba(255, 255, 255, 0.65);
    flex: 1;
  }

  .review-author {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 20px;
  }

  .review-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 4px;
  }

  .review-role {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.36);
    letter-spacing: 0.06em;
  }

  @media (max-width: 900px) {
    .reviews-grid {
      grid-template-columns: 1fr;
      max-width: 560px;
      margin-inline: auto;
    }
  }
</style>
